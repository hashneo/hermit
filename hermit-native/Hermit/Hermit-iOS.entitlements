<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- outbound HTTPS to Hermit server -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- keychain-sharing scoped to team+bundle so tokens survive app updates -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)$(HERMIT_BUNDLE_ID)</string>
	</array>
</dict>
</plist>
