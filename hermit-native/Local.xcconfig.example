// Local.xcconfig.example
//
// Copy this file to Local.xcconfig and fill in your own values.
// Local.xcconfig is gitignored — never commit it.
//
//   cp hermit-native/Local.xcconfig.example hermit-native/Local.xcconfig
//
// Then edit Local.xcconfig with your Apple Developer details.

// Your Apple Developer Team ID.
// Find it at https://developer.apple.com/account → Membership → Team ID
HERMIT_TEAM_ID = YOUR_TEAM_ID

// Bundle identifier for the app.
// Must be unique to you and registered in your developer account.
// e.g. com.yourname.hermit-native
HERMIT_BUNDLE_ID = com.yourname.hermit-native
