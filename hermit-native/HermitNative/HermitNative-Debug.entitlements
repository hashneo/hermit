<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox disabled in debug so the app can read config/hermit.yaml
	     and write diagnostic logs without Keychain permission prompts. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<!-- hermit-y9x: embedded Go server binds a TCP port -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- outbound HTTP to local / remote server -->
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.device.microphone</key>
	<true/>
	<!-- hermit-1ow: Multipeer Connectivity pairing handshake -->
	<key>com.apple.developer.nearby-interaction</key>
	<true/>
</dict>
</plist>
