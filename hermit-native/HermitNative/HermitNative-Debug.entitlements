<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- hermit-hy4: sandbox ON in all configurations; subprocess fallback removed -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- hermit-y9x: embedded Go server binds a TCP port -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- outbound HTTP to local / remote server -->
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.device.microphone</key>
	<true/>
	<!-- Note: com.apple.developer.nearby-interaction requires a provisioned
	     development certificate and is only present in HermitNative.entitlements
	     (Release). Debug builds use ad-hoc signing and cannot include it. -->
</dict>
</plist>
