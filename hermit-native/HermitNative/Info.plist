<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- MultipeerConnectivity: list the Bonjour service types MPC uses internally -->
	<key>NSBonjourServices</key>
	<array>
		<string>_hermit-pair._tcp</string>
		<string>_hermit-pair._udp</string>
		<string>_hermit._tcp</string>
	</array>

	<!-- NSUserActivity: activity types used for Handoff, scene restoration, and Spotlight -->
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.hashicorp.hermit.view-rfc</string>
		<string>com.hashicorp.hermit.handoff</string>
	</array>

	<!-- Microphone access: required for voice RFC dictation via SFSpeechRecognizer -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Hermit uses the microphone to let you dictate RFC content using your voice.</string>

	<!-- Speech recognition access: required for on-device STT via SFSpeechRecognizer -->
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Hermit uses on-device speech recognition to transcribe your voice into RFC text.</string>

	<!-- URL scheme for deep linking: hermit://rfc/<encoded-path> -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.hashicorp.hermit</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>hermit</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
