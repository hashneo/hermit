# Local machine overrides (device IDs, signing identity)
/.local.mk
/.env
/hermit-native/Local.xcconfig
.opencode/
ui/node_modules/
ui/dist/
ui/*.tsbuildinfo

# macOS
.DS_Store

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
bin/hermit
/.tmp
/hello-hermit
/data/gitea/
/data/hermit/
/.tmp/gitea-token.env

# Embedded dev config (copied by make native-embed-config, contains secrets)
/hermit-native/Hermit/DevConfig/hermit.yaml
/hermit-native/Hermit/DevConfig/gitea-token-export.sh

# Native app build output
Hermit.app/
HermitNative.app/
hermit-native/build/
hermit-native/Hermit.xcodeproj/project.xcworkspace/xcuserdata/
hermit-native/Hermit.xcodeproj/xcuserdata/
hermit-native/**/*.xcuserstate
hermit-native/DerivedData/

# Local repos config (team/personal — not committed; copy from hermit-repos.example.json)
/config/hermit-repos.*.json

# gomobile build artifacts
hermit-native/Hermit/HermitServer.xcframework/
.idea/
scripts/__pycache__/
